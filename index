<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Budget Familiare</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  :root {
    --bg: #F7F7F5;
    --surface: #FFFFFF;
    --border: #E8E6E1;
    --text: #1A1A18;
    --text-muted: #8A8880;
    --green: #2D7A4F;
    --green-bg: #EBF5F0;
    --red: #C0392B;
    --red-bg: #FDEDEC;
    --yellow: #B7770D;
    --yellow-bg: #FEF9EC;
    --accent: #2C3E50;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    padding: 0 0 40px;
  }

  header {
    background: var(--accent);
    color: white;
    padding: 20px 16px 16px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  header h1 {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.3px;
  }

  header p {
    font-size: 12px;
    opacity: 0.6;
    margin-top: 2px;
  }

  .refresh-btn {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
  }

  section {
    margin: 16px 12px 0;
  }

  .section-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
    padding-left: 2px;
  }

  /* SALDI */
  .saldi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .saldo-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
  }

  .saldo-card.negativo {
    background: var(--red-bg);
    border-color: #F5C6C2;
  }

  .saldo-nome {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .saldo-importo {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text);
  }

  .saldo-importo.negativo { color: var(--red); }
  .saldo-importo.positivo { color: var(--green); }

  /* PROGRESSIVO */
  .progressivo-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .prog-row {
    display: grid;
    grid-template-columns: 80px repeat(5, 1fr);
    gap: 0;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
  }

  .prog-row:last-child { border-bottom: none; }

  .prog-row.header {
    background: var(--accent);
    color: white;
    font-weight: 600;
    font-size: 10px;
  }

  .prog-row.rosso { background: var(--red-bg); }
  .prog-row.warning { background: var(--yellow-bg); }

  .prog-cell {
    padding: 8px 6px;
    text-align: right;
    border-right: 1px solid var(--border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prog-cell:first-child { text-align: left; }
  .prog-cell:last-child { border-right: none; }
  .prog-row.header .prog-cell { border-right-color: rgba(255,255,255,0.2); }

  .val-neg { color: var(--red); font-weight: 600; }
  .val-pos { color: var(--green); }

  /* SPESA LABEL */
  .spesa-label {
    font-size: 10px;
    color: var(--text-muted);
    padding: 4px 8px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    grid-column: 1 / -1;
  }

  /* PIVOT */
  .pivot-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .pivot-row {
    display: grid;
    grid-template-columns: 1fr 70px 70px 70px;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }

  .pivot-row:last-child { border-bottom: none; }

  .pivot-row.header {
    background: var(--accent);
    color: white;
    font-weight: 600;
    font-size: 10px;
  }

  .pivot-row.sforato { background: var(--red-bg); }
  .pivot-row.ok { background: var(--green-bg); }

  .pivot-cell {
    padding: 8px 8px;
    text-align: right;
    border-right: 1px solid var(--border);
    white-space: nowrap;
  }

  .pivot-cell:first-child { text-align: left; }
  .pivot-cell:last-child { border-right: none; }
  .pivot-row.header .pivot-cell { border-right-color: rgba(255,255,255,0.2); }

  /* LOADING */
  .loading {
    text-align: center;
    color: var(--text-muted);
    padding: 40px 20px;
    font-size: 13px;
  }

  .totale-row {
    font-weight: 700;
    background: #F0EDE8 !important;
    border-top: 2px solid var(--border) !important;
  }
</style>
</head>
<body>

<header>
  <h1>Budget Familiare</h1>
  <p id="last-update">Caricamento...</p>
  <button class="refresh-btn" onclick="loadData()">↻ Aggiorna</button>
</header>

<section>
  <div class="section-title">Saldi attuali</div>
  <div class="saldi-grid" id="saldi-container">
    <div class="loading">Caricamento...</div>
  </div>
</section>

<section>
  <div class="section-title">Progressivo mese</div>
  <div id="progressivo-container">
    <div class="loading">Caricamento...</div>
  </div>
</section>

<section>
  <div class="section-title">Spese per categoria</div>
  <div id="pivot-container">
    <div class="loading">Caricamento...</div>
  </div>
</section>

<script>
const SHEET_ID = '1GSdsAyeQzmTuFfSeSL5gu5zBBfdOkxqSgOs-oMRo23A';
const SHEET_NAME = 'Dashboard';
const URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(SHEET_NAME)}`;

function fmt(val) {
  if (val === null || val === undefined || val === '') return '—';
  const n = parseFloat(val);
  if (isNaN(n)) return val;
  return new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 }).format(n);
}

function parseSheet(rows) {
  // Parse flat Dashboard sheet into sections
  const data = { saldi: [], progressivo: [], pivot: [] };
  let section = null;
  let headers = [];

  for (let i = 0; i < rows.length; i++) {
    const row = rows[i].c.map(c => c ? (c.v !== null ? c.v : (c.f || '')) : '');
    const first = String(row[0]).trim();

    if (first === 'Saldi Real Time') { section = 'saldi'; headers = []; continue; }
    if (first === 'Progressivo') { section = 'progressivo'; headers = []; continue; }
    if (first === 'Pivot Categorie') { section = 'pivot'; headers = []; continue; }

    if (first === 'Conto' || first === 'Data' || first === 'Categoria') {
      headers = row.map(h => String(h).trim());
      continue;
    }

    if (section === 'saldi' && first !== '') {
      data.saldi.push({ conto: row[0], importo: row[1], data: row[2] });
    }
    if (section === 'progressivo' && first !== '') {
      data.progressivo.push({
        data: row[0], chebanca: row[1], ca: row[2],
        ing: row[3], bbva: row[4], contanti: row[5], spesa: row[6]
      });
    }
    if (section === 'pivot' && first !== '' && first !== 'Totale complessivo') {
      data.pivot.push({
        categoria: row[0], effettivo: row[1], previsto: row[2], scostamento: row[3]
      });
    }
  }
  return data;
}

function renderSaldi(saldi) {
  const container = document.getElementById('saldi-container');
  if (!saldi.length) { container.innerHTML = '<div class="loading">Nessun dato</div>'; return; }

  // Calcola totale
  const totale = saldi.reduce((s, r) => s + (parseFloat(r.importo) || 0), 0);

  let html = saldi.map(s => {
    const v = parseFloat(s.importo) || 0;
    const neg = v < 0;
    return `<div class="saldo-card ${neg ? 'negativo' : ''}">
      <div class="saldo-nome">${s.conto}</div>
      <div class="saldo-importo ${neg ? 'negativo' : 'positivo'}">${fmt(v)}</div>
    </div>`;
  }).join('');

  // Totale card full width
  html += `<div class="saldo-card" style="grid-column: 1/-1; display:flex; justify-content:space-between; align-items:center;">
    <div class="saldo-nome" style="font-weight:600; color:var(--text)">Totale</div>
    <div class="saldo-importo ${totale < 0 ? 'negativo' : 'positivo'}">${fmt(totale)}</div>
  </div>`;

  container.innerHTML = html;
}

function renderProgressivo(prog) {
  const container = document.getElementById('progressivo-container');
  if (!prog.length) { container.innerHTML = '<div class="loading">Nessun dato</div>'; return; }

  const conti = ['CheBanca', 'CA', 'ING', 'BBVA', 'Cont.'];
  let html = `<div class="progressivo-table">
    <div class="prog-row header">
      <div class="prog-cell">Data</div>
      ${conti.map(c => `<div class="prog-cell">${c}</div>`).join('')}
    </div>`;

  prog.forEach(r => {
    const vals = [r.chebanca, r.ca, r.ing, r.bbva, r.contanti].map(v => parseFloat(v) || 0);
    const hasNeg = vals.some(v => v < 0);
    const hasLow = !hasNeg && vals.some(v => v < 50);
    const rowClass = hasNeg ? 'rosso' : hasLow ? 'warning' : '';

    // Data formatting
    let dataStr = r.data || '';
    if (dataStr.length > 5) dataStr = dataStr.substring(0, 5); // dd/mm

    html += `<div class="prog-row ${rowClass}">
      <div class="prog-cell">${dataStr}</div>
      ${vals.map(v => `<div class="prog-cell ${v < 0 ? 'val-neg' : ''}">${fmt(v)}</div>`).join('')}
    </div>`;

    if (r.spesa) {
      html += `<div class="prog-row"><div class="spesa-label">${r.spesa}</div></div>`;
    }
  });

  html += '</div>';
  container.innerHTML = html;
}

function renderPivot(pivot) {
  const container = document.getElementById('pivot-container');
  if (!pivot.length) { container.innerHTML = '<div class="loading">Nessun dato</div>'; return; }

  let html = `<div class="pivot-table">
    <div class="pivot-row header">
      <div class="pivot-cell">Categoria</div>
      <div class="pivot-cell">Effett.</div>
      <div class="pivot-cell">Prev.</div>
      <div class="pivot-cell">Scost.</div>
    </div>`;

  pivot.forEach(r => {
    const sc = parseFloat(r.scostamento) || 0;
    const rowClass = sc < -5 ? 'sforato' : sc > 5 ? 'ok' : '';
    html += `<div class="pivot-row ${rowClass}">
      <div class="pivot-cell">${r.categoria}</div>
      <div class="pivot-cell">${fmt(r.effettivo)}</div>
      <div class="pivot-cell">${fmt(r.previsto)}</div>
      <div class="pivot-cell ${sc < 0 ? 'val-neg' : 'val-pos'}">${fmt(sc)}</div>
    </div>`;
  });

  html += '</div>';
  container.innerHTML = html;
}

async function loadData() {
  document.getElementById('last-update').textContent = 'Aggiornamento...';
  try {
    const res = await fetch(URL + '&nocache=' + Date.now());
    const text = await res.text();
    const json = JSON.parse(text.replace(/^[^{]+/, '').replace(/[^}]+$/, ''));
    const rows = json.table.rows;

    const data = parseSheet(rows);
    renderSaldi(data.saldi);
    renderProgressivo(data.progressivo);
    renderPivot(data.pivot);

    const now = new Date().toLocaleString('it-IT', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
    document.getElementById('last-update').textContent = 'Aggiornato ' + now;
  } catch(e) {
    document.getElementById('last-update').textContent = 'Errore caricamento';
    console.error(e);
  }
}

loadData();
</script>
</body>
</html>
